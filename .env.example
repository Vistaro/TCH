# Database
DB_HOST=localhost
DB_NAME=tch_placements
DB_USER=
DB_PASS=

# App
APP_ENV=development
APP_URL=https://tch.intelligentae.co.uk
APP_NAME="TCH Placements"

# Session
SESSION_LIFETIME=3600

# Nexus Hub (central Bug/FR tracker) — in-app reporter forwards submissions here
NEXUS_HUB_URL=https://hub.intelligentae.co.uk
NEXUS_HUB_PROJECT_SLUG=tch
# NEXUS_HUB_TOKEN is generated in the Hub web UI: log in as Super Admin →
# Tokens → Create Token → label "TCH Agent", scope to the `tch` project,
# copy the plain token ONCE (shown only on create) and paste below.
# Leave blank on dev environments where the reporter is not yet wired up.
NEXUS_HUB_TOKEN=
